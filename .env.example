# ── Google Gemini AI (requis) ──────────────────────────────────────────────
# Obtenir sur : https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ── YouTube Data API v3 (optionnel — pour de vraies recherches musicales) ──
# 1. Aller sur https://console.cloud.google.com
# 2. Activer "YouTube Data API v3"
# 3. Créer une clé API dans "Credentials"
YOUTUBE_API_KEY="YOUR_YOUTUBE_API_KEY"

# ── Firebase (pour les comptes utilisateurs) ───────────────────────────────
# 1. Aller sur https://console.firebase.google.com
# 2. Créer un projet → Activer "Authentication" → Google Sign-In
# 3. Copier la config depuis Project Settings > Your apps > Web app
FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
FIREBASE_MESSAGING_SENDER_ID="123456789"
FIREBASE_APP_ID="1:123456789:web:abc123"

# ── App URL ────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
